# Grupo GS - Variables de entorno
# Copiar a .env.local y completar los valores
# En Vercel: Settings > Environment Variables

# Admin (cambiar en producción)
ADMIN_EMAIL=admin@grupogscol.com
ADMIN_PASSWORD=GrupoGS2026!

# Neon PostgreSQL (requerido para leads y config del bot)
DATABASE_URL=postgresql://user:pass@host/db?sslmode=require

# Vercel Blob (para imágenes en galería/blog)
BLOB_READ_WRITE_TOKEN=vercel_blob_rw_xxx

# OpenAI - Requerido para el chat bot
OPENAI_API_KEY=sk-xxx
